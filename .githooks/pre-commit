#!/usr/bin/env bash
# ==============================================================================
# Pre-Commit Hook - Secret Leak Prevention
# ==============================================================================
# Prevents accidental commit of:
#   1. .env files (any variant)
#   2. Credential/key files
#   3. Hardcoded secrets detected in staged file contents
#
# Install: git config core.hooksPath .githooks
# (Automatically done via npm prepare script)
# ==============================================================================

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

BLOCKED=0

# ==============================================================================
# Layer 1: Block dangerous filenames from being committed
# ==============================================================================

BLOCKED_FILE_PATTERNS=(
  '\.env$'
  '\.env\.'
  'serviceAccountKey\.json'
  'credentials\.json'
  'firebase-credentials'
  'gcp-credentials'
  'aws-credentials'
  '\.pem$'
  '\.key$'
  '\.p12$'
  '\.pfx$'
  '\.keystore$'
  '\.jks$'
  'id_rsa'
  'id_dsa'
  'id_ecdsa'
  'id_ed25519'
  'mongodb-credentials'
)

# Allow .env.example explicitly
ALLOW_PATTERNS=(
  '\.env\.example$'
)

staged_files=$(git diff --cached --name-only --diff-filter=ACR 2>/dev/null || true)

if [ -n "$staged_files" ]; then
  while IFS= read -r file; do
    # Check if file matches an allow pattern
    allowed=0
    for allow in "${ALLOW_PATTERNS[@]}"; do
      if echo "$file" | grep -qiE "$allow"; then
        allowed=1
        break
      fi
    done
    [ "$allowed" -eq 1 ] && continue

    # Check if file matches a blocked pattern
    for pattern in "${BLOCKED_FILE_PATTERNS[@]}"; do
      if echo "$file" | grep -qiE "$pattern"; then
        echo -e "${RED}BLOCKED${NC} Sensitive file staged for commit: ${YELLOW}${file}${NC}"
        BLOCKED=1
        break
      fi
    done
  done <<< "$staged_files"
fi

# ==============================================================================
# Layer 2: Scan staged file contents for secret patterns
# ==============================================================================

SECRET_PATTERNS=(
  # AWS
  'AKIA[0-9A-Z]{16}'
  # Generic API keys / tokens (long hex strings assigned to key-like variables)
  '(api_key|apikey|api_secret|secret_key|access_key|auth_token)\s*[=:]\s*["'"'"'][a-zA-Z0-9/+=_-]{20,}'
  # Private keys
  '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'
  # JWT tokens (three base64 segments separated by dots)
  'eyJ[a-zA-Z0-9_-]{10,}\.eyJ[a-zA-Z0-9_-]{10,}\.[a-zA-Z0-9_-]+'
  # Connection strings with passwords
  'mongodb(\+srv)?://[^:]+:[^@]+@'
  'postgres(ql)?://[^:]+:[^@]+@'
  'mysql://[^:]+:[^@]+@'
  'redis://:[^@]+@'
  # Razorpay live keys (allow test keys)
  'rzp_live_[a-zA-Z0-9]+'
  # Google API keys
  'AIzaSy[a-zA-Z0-9_-]{33}'
  # Slack tokens
  'xox[bpors]-[a-zA-Z0-9-]+'
  # GitHub tokens
  'gh[pousr]_[a-zA-Z0-9]{36,}'
  # Generic password assignments
  'password\s*[=:]\s*["'"'"'][^\s"'"'"']{8,}'
)

# Only scan text files that are staged (skip binaries, skip .env.example)
if [ -n "$staged_files" ]; then
  while IFS= read -r file; do
    # Skip .env.example — it's a template with empty values
    if echo "$file" | grep -qiE '\.env\.example$'; then
      continue
    fi

    # Skip binary files, images, lock files
    if echo "$file" | grep -qiE '\.(png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|pdf|zip|tar|gz|lock|min\.js|min\.css|map)$'; then
      continue
    fi

    # Skip node_modules (should never be staged, but just in case)
    if echo "$file" | grep -q 'node_modules/'; then
      continue
    fi

    # Skip the hooks directory itself (contains detection patterns, not secrets)
    if echo "$file" | grep -q '\.githooks/'; then
      continue
    fi

    # Get the staged content of the file
    staged_content=$(git diff --cached -p -- "$file" 2>/dev/null | grep '^+' | grep -v '^+++' || true)

    if [ -n "$staged_content" ]; then
      for pattern in "${SECRET_PATTERNS[@]}"; do
        match=$(echo "$staged_content" | grep -iE "$pattern" 2>/dev/null | head -1 || true)
        if [ -n "$match" ]; then
          # Truncate the match for display (don't print the actual secret)
          truncated=$(echo "$match" | cut -c1-80)
          echo -e "${RED}BLOCKED${NC} Possible secret in ${YELLOW}${file}${NC}"
          echo -e "  Pattern: ${pattern}"
          echo -e "  Near:    ${truncated}..."
          BLOCKED=1
          break
        fi
      done
    fi
  done <<< "$staged_files"
fi

# ==============================================================================
# Verdict
# ==============================================================================

if [ "$BLOCKED" -ne 0 ]; then
  echo ""
  echo -e "${RED}========================================${NC}"
  echo -e "${RED} COMMIT BLOCKED - Secrets detected!${NC}"
  echo -e "${RED}========================================${NC}"
  echo ""
  echo "Bots scan every GitHub commit in real-time for exposed secrets."
  echo "Your keys can be compromised within seconds of pushing."
  echo ""
  echo "To fix:"
  echo "  1. Remove the flagged files:  git reset HEAD <file>"
  echo "  2. Add them to .gitignore"
  echo "  3. If already pushed, rotate ALL exposed credentials immediately"
  echo ""
  echo "To bypass (emergencies only):"
  echo "  git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
