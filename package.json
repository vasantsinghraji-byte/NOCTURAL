{
  "name": "nocturnal-monorepo",
  "version": "1.0.0",
  "description": "Nocturnal Healthcare Platform - Microservices Architecture",
  "main": "server.js",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "install:all": "npm install && npm run install:shared",
    "install:shared": "cd packages/shared && npm install",
    "test:shared": "npm test --workspace=@nocturnal/shared",
    "test:patient-booking": "npm test --workspace=@nocturnal/patient-booking-service",
    "start:patient-booking": "npm start --workspace=@nocturnal/patient-booking-service",
    "dev:patient-booking": "npm run dev --workspace=@nocturnal/patient-booking-service",
    "start": "node --max-old-space-size=2048 server.js",
    "dev": "nodemon --max-old-space-size=2048 server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm --prefix client run serve\"",
    "start:all": "concurrently \"npm start\" \"npm --prefix client run serve\"",
    "frontend": "npm --prefix client run serve",
    "build": "npm run build:prod",
    "prebuild:frontend": "npm --prefix client ci --include=dev",
    "build:frontend": "npm --prefix client run build",
    "build:client": "npm run build:frontend",
    "build:prod": "cross-env NODE_ENV=production npm run build:frontend",
    "optimize": "npm run build:frontend",
    "db:indexes": "node scripts/add-indexes.js",
    "db:migrate": "node scripts/add-indexes.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "monitor:db": "node scripts/monitor-db.js",
    "monitor:rate-limits": "node scripts/monitor-rate-limits.js",
    "monitor": "concurrently \"npm run monitor:db\" \"npm run monitor:rate-limits\"",
    "deploy": "npm run build:prod && npm start",
    "pm2:start": "pm2 start ecosystem.config.js --env development",
    "pm2:start:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop nocturnal-api",
    "pm2:restart": "pm2 restart nocturnal-api",
    "pm2:reload": "pm2 reload nocturnal-api",
    "pm2:delete": "pm2 delete nocturnal-api",
    "pm2:logs": "pm2 logs nocturnal-api",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "pm2:reset": "pm2 reset nocturnal-api",
    "pm2:flush": "pm2 flush",
    "test": "node ./node_modules/jest/bin/jest.js --config jest.fast.config.js",
    "test:all": "node ./node_modules/jest/bin/jest.js",
    "test:watch": "node ./node_modules/jest/bin/jest.js --config jest.fast.config.js --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "test:smoke": "jest tests/smoke",
    "test:models": "jest tests/unit/models",
    "test:controllers": "jest tests/unit/controllers",
    "test:middleware": "jest tests/unit/middleware",
    "test:utils": "jest tests/unit/utils",
    "test:api": "jest tests/integration",
    "test:ci": "jest --ci --coverage --runInBand --forceExit",
    "test:deploy-gate": "npm run build:prod && node ./node_modules/jest/bin/jest.js --runInBand --runTestsByPath tests/unit/validation/frontend-legacy-auth-retirement.test.js tests/unit/validation/frontend-route-helper-centralization.test.js tests/unit/validation/frontend-page-api-dependency-map.test.js tests/unit/validation/frontend-admin-doctor-api-contract.test.js tests/unit/validation/frontend-provider-admin-booking-contract.test.js tests/unit/validation/frontend-auth-flow-standardization.test.js tests/unit/validation/frontend-session-standardization.test.js tests/unit/validation/frontend-runtime-role-routing-and-doctor-dashboard-contract.test.js tests/unit/validation/frontend-build-output-csp-contract.test.js tests/unit/validation/frontend-build-artifact-contract.test.js tests/unit/validation/frontend-final-contract-closures.test.js tests/unit/validation/frontend-canonical-nav-contract.test.js tests/unit/validation/admin-route-contract.test.js tests/smoke/production-entrypoint-health.test.js tests/smoke/production-built-frontend-playwright.test.js",
    "security:scan": "node scripts/security-scan.js --target http://localhost:5000",
    "security:scan:full": "node scripts/security-scan.js --target http://localhost:5000 --mode full",
    "security:rotate": "node scripts/rotate-secrets.js",
    "security:vault:init": "node scripts/init-vault.js",
    "db:backup": "node scripts/backup-database.js backup",
    "db:backup:list": "node scripts/backup-database.js list",
    "db:backup:restore": "node scripts/backup-database.js restore",
    "db:setup-security": "node scripts/setup-mongodb-security.js",
    "db:setup-replica": "node scripts/setup-replica-set.js",
    "db:enable-auth": "scripts\\enable-mongodb-auth.bat",
    "prepare": "git config core.hooksPath .githooks",
    "setup:env": "node scripts/setup-env.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.919.0",
    "@aws-sdk/s3-request-presigner": "^3.919.0",
    "@google-cloud/storage": "^7.18.0",
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.3.0",
    "file-type": "^16.5.4",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "mongoose": "^8.19.0",
    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "pm2": "^6.0.13",
    "rate-limit-redis": "^4.2.3",
    "razorpay": "^2.9.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.18.3",
    "winston-logstash": "^1.2.1",
    "winston-loki": "^6.1.3",
    "xss-clean": "^0.1.4"
  },
  "optionalDependencies": {
    "node-vault": "^0.10.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.51.0",
    "eslint-plugin-security": "^1.7.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "playwright": "^1.59.1",
    "supertest": "^7.1.4"
  }
}
